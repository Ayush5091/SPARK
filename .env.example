# =====================
# Database (PostgreSQL)
# =====================
DATABASE_URL=postgresql://user:password@host:5432/dbname

# =====================
# Google OAuth
# =====================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# =====================
# JWT Authentication
# =====================
JWT_SECRET=your-strong-random-secret
# JWT_ALGORITHM is used by the Python backend (python_app_legacy); the Next.js backend uses HS256 by default
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# =====================
# Session (Python backend)
# =====================
SESSION_SECRET_KEY=your-strong-random-session-secret

# =====================
# SMTP / Email
# =====================
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-email-password
MAIL_FROM=your-email@gmail.com
MAIL_FROM_NAME=AICTE App
